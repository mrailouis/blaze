{
	"schemaVersion": 1,
	"id": "larp-addon",
	"version": "${version}",
	"name": "${mod_name}",
	"description": "Private QOL addons to larp!",
	"authors": [
		"mrai"
	],
	"license": "All Rights Reserved",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "me.mrai.larpclient.addon.LarpClientAddon",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"larpclient-addon.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=22",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"larpclient": "*"
	}
}
