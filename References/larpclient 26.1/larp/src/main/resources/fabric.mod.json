{
	"schemaVersion": 1,
	"id": "larpclient",
	"version": "${version}",
	"name": "${mod_name}",
	"description": "Larper? I hardly know her!",
	"authors": [
		"mrai"
	],
	"contact": {
		"homepage": "https://larpclient.pages.dev/",
		"sources": "https://github.com/mrailouis/larpclient-public/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/larpclient/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "me.mrai.larpclient.LarpClientClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"larpclient.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=22",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
